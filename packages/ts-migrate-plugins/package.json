    },
    {
      "name": "John Haytko",
      "url": "https://github.com/jjjjhhhhhh"
    },
    {
      "name": "Joe Lencioni",
      "url": "https://github.com/lencioni"
    }
  ],
  "homepage": "https://github.com/ObieMunoz/ts-migrate#readme",
  "license": "MIT",
  "dependencies": {
    "@obiemunoz/ts-migrate-server": "^0.1.33",
    "eslint": "^9.18.0",
    "jiti": "^2.4.2",
    "jscodeshift": "^0.13.0",
    "json-schema": "^0.4.0"
  },
  "gitHead": "7acf6067f15c9bb367cda9c47fcfb4203dcc54f3",
