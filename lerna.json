{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "0.2.4",
  "npmClient": "yarn",
  "packages": ["packages/*"],
  "command": {
    "run": {
      "stream": true
    },
    "version": {
      "conventionalCommits": true,
      "createRelease": "github",
      "message": "chore(release): publish v%v [skip ci]"
    }
  }
}
